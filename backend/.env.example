PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/vidchat-ai
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_random
JWT_EXPIRES_IN=7d

# Groq API — FREE, no credit card needed
# Sign up at https://console.groq.com → API Keys → Create API Key
GROQ_API_KEY=your_groq_api_key_here

# YouTube Data API (optional, improves video metadata)
YOUTUBE_API_KEY=your_youtube_data_api_key

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
